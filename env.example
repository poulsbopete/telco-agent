# Copy to .env.local (local dev) or Vercel project environment variables.

# online | offline
DEMO_MODE=online

# --- Online mode (Agent Builder via Kibana) ---
# Must be the Kibana URL (*.kb.*.elastic.cloud), NOT the Elasticsearch URL (*.es.*).
KIBANA_BASE_URL=https://your-project.kb.us-east-1.aws.elastic.cloud
KIBANA_API_KEY=

# Optional default agent when persona picker not used
# KIBANA_AGENT_ID=tmobile-customer-care

# --- Offline mode (local RAG) ---
LOCAL_ES_URL=http://localhost:9200
TELCO_INDEX=telco-tmobile-kb

# Optional local LLM for offline RAG synthesis
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
