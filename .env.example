# Elastic Cloud Serverless (online prep + Agent Builder)
ES_URL=https://your-project.es.us-east-1.aws.elastic.cloud
ES_API_KEY=
KIBANA_BASE_URL=https://your-project.kb.us-east-1.aws.elastic.cloud
KIBANA_API_KEY=

# Jina Reader (online crawl only)
JINA_API_KEY=

# Index and inference
TELCO_INDEX=telco-tmobile-kb
INFERENCE_ID=jina-embeddings-v3

# Crawl limits
CRAWL_MAX_PAGES=200
CRAWL_MAX_DEPTH=3

# Local Elasticsearch (offline demo)
LOCAL_ES_URL=http://localhost:9200

# Web UI (web/.env.local)
# DEMO_MODE=online
# DEMO_MODE=offline
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
